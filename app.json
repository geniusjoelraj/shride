{
  "expo": {
    "name": "Shride",
    "slug": "demo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/shride-app-logo.png",
    "scheme": "demo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8F3E1",
        "foregroundImage": "./assets/images/shride-app-logo.png",
        "backgroundImage": "./assets/images/shride-app-logo.png",
        "monochromeImage": "./assets/images/shride-app-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tadano_tensai.demo",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyC-MoKyjxcX653aXuBIUh1EGhW0-uGiAYE"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/shride-app-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Shride to use your location to find nearby rides."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c2fc8923-ecd5-44b8-bb94-1a59efbce20e"
      }
    },
    "owner": "tadano_tensai"
  }
}